#include <bits/stdc++.h>
using namespace std;
 
#define Code_By_Abdelwabab ios::sync_with_stdio(false); cin.tie(nullptr); cout.tie(nullptr);
#define endl "\n"
#define int long long
 
struct Node{
    int val;
    Node *left, *right;
    Node (){ val = 0; left = right = nullptr; }
    Node (int v){ val = v; left = right = nullptr; }
    Node (Node *l, Node *r){
        left = l; right = r;
        val = 0;
        if(left) val += left->val;
        if(right) val += right->val;
    }
};
 
struct PST {
    int n;
    vector<Node*> roots;
 
    PST(int n) : n(n) {
        roots.clear();
        roots.push_back(nullptr);
    }
 
    Node* init(int l, int r, vector<int>& a){
        if(l == r) return new Node(a[l]);
        int mid = (l+r)/2;
        Node* L = init(l, mid, a);
        Node* R = init(mid+1, r, a);
        return new Node(L, R);
    }
 
    Node* update(Node* node, int l, int r, int idx, int x){
        if(l == r) return new Node(x);
        int mid = (l + r) / 2;
        if(idx <= mid){
            Node* L = update(node->left, l, mid, idx, x);
            return new Node(L, node->right);
        }
        Node* R = update(node->right, mid+1, r, idx, x);
        return new Node(node->left, R);
    }
 
    int query(Node* node, int l, int r, int ql, int qr){
        if(!node || l > qr || r < ql) return 0;
        if(l >= ql && r <= qr) return node->val;
        int mid = (l+r)/2;
        return query(node->left, l, mid, ql, qr) +
               query(node->right, mid+1, r, ql, qr);
    }
 
    int query(int id, int l, int r){
        return query(roots[id], 0, n-1, l, r);
    }
 
    Node* update(int id, int idx, int x){
        return update(roots[id], 0, n-1, idx, x);
    }
};
 
void solve(){
    int n, q;
    cin >> n >> q;
    vector<int> v(n);
    for(int i = 0; i < n; i++) cin >> v[i];
 
    PST pst(n);
    pst.roots.push_back(pst.init(0, n - 1, v));
 
    while(q--){
        int t;
        cin >> t;
        if(t == 1){
            int k, a, x;
            cin >> k >> a >> x;
            a--;
            pst.roots[k] = pst.update(k, a, x);
        }
        else if(t == 2){
            int k, a, b;
            cin >> k >> a >> b;
            a--;
            b--;
            cout << pst.query(k, a, b) << endl;
        }
        else if(t == 3){
            int k;
            cin >> k;
            pst.roots.push_back(pst.roots[k]);
        }
    }
}
 
signed main(){
    Code_By_Abdelwabab
    solve();
}
